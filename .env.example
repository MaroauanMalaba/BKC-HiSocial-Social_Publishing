# Random secret for JWT signing — generate with: openssl rand -hex 32
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Your app's public URL — Ayrshare needs this to serve media files.
# In local dev, use an ngrok tunnel: https://abc123.ngrok.io
# In production, use your real domain.
PUBLIC_BASE_URL=

# Ayrshare API key — get it at app.ayrshare.com → Settings → API Key
# One key covers all platforms (Instagram, Facebook, TikTok, YouTube, ...)
# Each user gets their own Ayrshare profile (created automatically on first connect).
AYRSHARE_API_KEY=
