# ─────────────────────────────────────────────────────────────────────────────
# HiSocial Studio — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random secret for JWT signing.
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-openssl-rand-hex-32

# ── URLs ──────────────────────────────────────────────────────────────────────
# Internal base URL (used for redirects, API calls from server side)
APP_BASE_URL=http://localhost:3000

# Public URL reachable from the internet.
# Required for Meta (Instagram/Facebook) to fetch media files.
# Local dev → start ngrok: ngrok http 3000 → paste the https URL here.
# Production → your real domain (e.g. https://studio.hisocial.at)
PUBLIC_BASE_URL=

# ── Meta (Instagram + Facebook) ───────────────────────────────────────────────
# Meta Developer App — https://developers.facebook.com/apps/
# App: HiSocial Studio (owned by BKC Consulting)
# App-ID: 940087908782876  ← already set, do not change unless you create a new app
#
# The App Secret is private — get it from:
# developers.facebook.com → App → App Settings → Basic → App Secret → "Show"
META_APP_ID=940087908782876
META_APP_SECRET=replace-with-meta-app-secret

# ── Zernio (Social Publishing API) ────────────────────────────────────────────
# Zernio handles OAuth connections + publishing to all platforms.
# Get the API key from: app.zernio.io → Settings → API Keys
# The key below is for the BKC/HiSocial workspace.
ZERNIO_API_KEY=replace-with-zernio-api-key
