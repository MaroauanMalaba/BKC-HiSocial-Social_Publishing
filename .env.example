# Random secret for JWT signing — generate with: openssl rand -hex 32
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# Required for Instagram + Facebook publishing.
# Meta requires a publicly reachable URL to fetch media from.
# In local dev, run an ngrok tunnel and paste the https URL here.
# Leave empty to disable IG/FB publishing (TikTok still works).
PUBLIC_BASE_URL=

# Base URL the OAuth callbacks redirect back to. Locally this is
# typically http://localhost:3000 (or your ngrok URL).
APP_BASE_URL=http://localhost:3000

# Meta (Facebook + Instagram) OAuth — create an app at developers.facebook.com
# Add http://localhost:3000/api/oauth/meta/callback as a Valid OAuth Redirect URI.
META_APP_ID=
META_APP_SECRET=

# TikTok OAuth — create an app at developers.tiktok.com
# Add http://localhost:3000/api/oauth/tiktok/callback as a Redirect URI.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
